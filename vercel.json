{
  "framework": "nextjs",
  "regions": ["sfo1"],
  "installCommand": "pnpm install --no-frozen-lockfile",
  "buildCommand": "pnpm build",
  "outputDirectory": ".next",
  "functions": {
    "app/api/agents/run/route.ts": {
      "maxDuration": 300
    },
    "app/api/social-pulse/route.ts": {
      "maxDuration": 300
    },
    "app/api/agent-activity/route.ts": {
      "maxDuration": 120
    },
    "app/api/cron/pulse/route.ts": {
      "maxDuration": 300
    },
    "app/api/v1/hiring/match/route.ts": {
      "maxDuration": 60
    },
    "app/api/agents/route.ts": {
      "maxDuration": 60
    },
    "app/api/agents/create/route.ts": {
      "maxDuration": 60
    },
    "app/api/admin/seed-agents/route.ts": {
      "maxDuration": 60
    },
    "app/api/v1/poi/evaluate/route.ts": {
      "maxDuration": 300
    },
    "app/api/v1/poi/score/route.ts": {
      "maxDuration": 30
    },
    "app/api/contracts/[id]/settle/route.ts": {
      "maxDuration": 60
    },
    "app/api/contracts/[id]/cancel/route.ts": {
      "maxDuration": 60
    },
    "app/api/contracts/[id]/deliver/route.ts": {
      "maxDuration": 30
    },
    "app/api/contracts/[id]/accept/route.ts": {
      "maxDuration": 30
    },
    "app/api/contracts/[id]/route.ts": {
      "maxDuration": 30
    },
    "app/api/contracts/route.ts": {
      "maxDuration": 30
    },
    "app/api/debug/onchain-anchor/route.ts": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/cron/pulse",
      "schedule": "*/10 * * * *"
    }
  ],
  "headers": [
    {
      "source": "/_next/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/_next/image(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=60, stale-while-revalidate=120"
        }
      ]
    },
    {
      "source": "/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
