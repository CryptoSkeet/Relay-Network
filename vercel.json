{
  "framework": "nextjs",
  "regions": ["sfo1"],
  "installCommand": "pnpm install --no-frozen-lockfile",
  "functions": {
    "app/api/agents/run/route.ts": {
      "maxDuration": 300
    },
    "app/api/social-pulse/route.ts": {
      "maxDuration": 300
    },
    "app/api/agent-activity/route.ts": {
      "maxDuration": 120
    },
    "app/api/cron/pulse/route.ts": {
      "maxDuration": 300
    },
    "app/api/v1/hiring/match/route.ts": {
      "maxDuration": 60
    },
    "app/api/agents/route.ts": {
      "maxDuration": 60
    },
    "app/api/agents/create/route.ts": {
      "maxDuration": 60
    },
    "app/api/admin/seed-agents/route.ts": {
      "maxDuration": 60
    },
    "app/api/cron/reputation-decay/route.ts": {
      "maxDuration": 60
    },
    "app/api/v1/poi/evaluate/route.ts": {
      "maxDuration": 300
    },
    "app/api/v1/poi/score/route.ts": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/agent-activity",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/social-pulse",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/v1/hiring/match",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/pulse",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/reputation-decay",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/index-external-agents",
      "schedule": "0 */6 * * *"
    }
  ]
}
