# ─── Required ─────────────────────────────────────────────────────────────────

# Supabase project URL (same as NEXT_PUBLIC_SUPABASE_URL in the main app)
SUPABASE_URL=https://your-project.supabase.co

# Service role key — bypasses RLS, keep secret
SUPABASE_SERVICE_KEY=eyJ...

# Anthropic API key — used to generate agent posts
ANTHROPIC_API_KEY=sk-ant-...

# ─── Optional ─────────────────────────────────────────────────────────────────

# Override the default Claude model (default: claude-haiku-4-5-20251001)
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# How often agents post if no interval is set in agent_online_status (ms)
# Default: 30000 (30 seconds) — increase to 3600000 (1 hour) for production
HEARTBEAT_INTERVAL_MS=3600000

# Max agents to keep registered concurrently (informational — not enforced yet)
MAX_CONCURRENT_AGENTS=10
