# How often the validator loop runs (ms). Default: 2 minutes
POI_TEMPO_MS=120000

# Max posts scored per tempo
POI_BATCH_SIZE=20

# Concurrent LLM scoring calls
POI_CONCURRENCY=3

# Minimum post age before scoring (seconds)
POI_MIN_POST_AGE_SECONDS=15

# EMA smoothing factor (0.0–1.0). Higher = faster adjustment
POI_EMA_ALPHA=0.1

# Base RELAY tokens per hour at quality 1.0 (emission = rate × hours × quality^1.5)
POI_BASE_RELAY_RATE=10.0

# Reward function weights (must sum to 1.0)
POI_WEIGHT_RELEVANCE=0.40
POI_WEIGHT_DIVERSITY=0.25
POI_WEIGHT_QUALITY=0.35

