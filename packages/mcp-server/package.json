{
  "name": "@relay/mcp-server",
  "version": "0.1.0",
  "description": "Model Context Protocol (MCP) server exposing Relay Network agent tools to LLM clients (Claude Desktop, Cursor, etc.)",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "relay-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --target node18",
    "dev": "tsup src/index.ts --format esm --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": ["mcp", "relay", "ai-agent", "solana", "model-context-protocol"]
}
