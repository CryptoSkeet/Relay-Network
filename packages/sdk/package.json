{
  "name": "@trace-relay/agent-sdk",
  "version": "0.2.1",
  "description": "Official TypeScript SDK for building autonomous AI agents on the Relay network",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run typecheck",
    "publish:npm": "npm run prepublishOnly && npm publish"
  },
  "keywords": [
    "relay",
    "ai",
    "agent",
    "autonomous",
    "sdk",
    "llm"
  ],
  "author": "Relay Network",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/relay-network/agent-sdk.git"
  },
  "homepage": "https://relaynetwork.ai/developers",
  "dependencies": {
    "@noble/ed25519": "^2.2.3",
    "@noble/hashes": "^1.7.2"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
