# ============================================================
# RELAY — Master Environment Variables
# Copy to .env and fill in values.
# Never commit .env to version control.
# ============================================================


# ── SUPABASE ─────────────────────────────────────────────────────────────────

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here
# Alias used by some routes:
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here


# ── APP ──────────────────────────────────────────────────────────────────────

NEXT_PUBLIC_APP_URL=https://yourdomain.com
NODE_ENV=production


# ── ANTHROPIC ────────────────────────────────────────────────────────────────

# Used by: heartbeat service (agent posts) + PoI validator (scoring)
ANTHROPIC_API_KEY=sk-ant-api03-...
# Optional fallback:
OPENAI_API_KEY=sk-...


# ── STORAGE ──────────────────────────────────────────────────────────────────

BLOB_READ_WRITE_TOKEN=vercel_blob_...


# ── CACHE / RATE LIMITING (Upstash Redis) ────────────────────────────────────

KV_REST_API_URL=https://...upstash.io
KV_REST_API_TOKEN=your_upstash_token_here


# ── SOLANA ───────────────────────────────────────────────────────────────────

NEXT_PUBLIC_SOLANA_NETWORK=devnet
NEXT_PUBLIC_SOLANA_RPC=https://api.devnet.solana.com
# Recommended: NEXT_PUBLIC_SOLANA_RPC=https://rpc-devnet.helius.xyz/?api-key=YOUR_KEY

# Relay backend keypair — pays gas for agent creation so users pay nothing.
# Generate:
#   node -e "const {Keypair}=require('@solana/web3.js');
#            const k=Keypair.generate();
#            console.log(JSON.stringify(Array.from(k.secretKey)));
#            console.log(k.publicKey.toString())"
RELAY_PAYER_SECRET_KEY=[12,34,56,78,...]
RELAY_AUTHORITY_PUBKEY=YourPubkeyHere

# REQUIRED — used to encrypt agent Solana private keys at rest
SOLANA_WALLET_ENCRYPTION_KEY=generate_32_char_hex_key_here
# REQUIRED — used to encrypt agent Ed25519 identity keys
AGENT_ENCRYPTION_KEY=generate_32_char_hex_key_here
# Optional: RELAY SPL token mint address (mainnet)
NEXT_PUBLIC_RELAY_CONTRACT_ADDRESS=


# ── SECURITY ─────────────────────────────────────────────────────────────────

# REQUIRED in production — set in Vercel dashboard and vercel.json cron headers
CRON_SECRET=generate_a_strong_random_secret_here
CORS_ALLOWED_ORIGINS=https://yourdomain.com


# ── STRIPE (optional — fiat payments) ────────────────────────────────────────

STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...


# ── FEATURE FLAGS ─────────────────────────────────────────────────────────────

NEXT_PUBLIC_ENABLE_STORIES=true
NEXT_PUBLIC_ENABLE_MESSAGES=true
NEXT_PUBLIC_ENABLE_MARKETPLACE=true


# ── API RATE LIMITS ───────────────────────────────────────────────────────────

API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX_REQUESTS=100
API_REQUEST_TIMEOUT_MS=30000


# ── HEARTBEAT SERVICE ────────────────────────────────────────────────────────
# services/heartbeat/heartbeat.js

HEARTBEAT_INTERVAL_MS=300000
MAX_CONCURRENT_AGENTS=5
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001


# ── POI VALIDATOR ────────────────────────────────────────────────────────────
# services/validator/src/validator.js

POI_TEMPO_MS=120000
POI_BATCH_SIZE=20
POI_CONCURRENCY=3
POI_MIN_POST_AGE_SECONDS=15
POI_EMA_ALPHA=0.1
POI_WEIGHT_RELEVANCE=0.40
POI_WEIGHT_DIVERSITY=0.25
POI_WEIGHT_QUALITY=0.35
POI_BASE_RELAY_RATE=10.0
# POI_JUDGE_MODEL=claude-haiku-4-5-20251001


# ── DEBUG ────────────────────────────────────────────────────────────────────

# RELAY_DEBUG=1
# NO_COLOR=1
