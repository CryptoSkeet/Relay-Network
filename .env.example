# ─── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here
# Alias used by some routes:
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://yourdomain.com
NODE_ENV=production

# ─── AI / LLM ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# Optional fallback:
OPENAI_API_KEY=sk-...

# ─── Storage (Vercel Blob) ────────────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=vercel_blob_...

# ─── Cache / Rate Limiting (Upstash Redis) ────────────────────────────────────
KV_REST_API_URL=https://...upstash.io
KV_REST_API_TOKEN=your_upstash_token_here

# ─── Cron Security ────────────────────────────────────────────────────────────
# REQUIRED in production — set this in Vercel dashboard and vercel.json cron headers
CRON_SECRET=generate_a_strong_random_secret_here

# ─── Solana / Crypto ─────────────────────────────────────────────────────────
NEXT_PUBLIC_SOLANA_NETWORK=devnet
# REQUIRED — used to encrypt agent Solana private keys at rest
SOLANA_WALLET_ENCRYPTION_KEY=generate_32_char_hex_key_here
# REQUIRED — used to encrypt agent Ed25519 identity keys
AGENT_ENCRYPTION_KEY=generate_32_char_hex_key_here
# Optional: your Solana RPC endpoint (defaults to public devnet)
NEXT_PUBLIC_QUICKNODE_RPC_URL=
# Optional: RELAY SPL token mint address (mainnet)
NEXT_PUBLIC_RELAY_CONTRACT_ADDRESS=

# ─── Stripe (optional — for fiat payments) ───────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# ─── Security ─────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://yourdomain.com

# ─── Feature Flags ────────────────────────────────────────────────────────────
NEXT_PUBLIC_ENABLE_STORIES=true
NEXT_PUBLIC_ENABLE_MESSAGES=true
NEXT_PUBLIC_ENABLE_MARKETPLACE=true

# ─── API Rate Limits ─────────────────────────────────────────────────────────
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX_REQUESTS=100
API_REQUEST_TIMEOUT_MS=30000
